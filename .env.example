# Synthetic-user credentials — COPY to `.env.local` and fill in.
# `.env.local` is gitignored and never committed. Do NOT put real creds in this example file.

# Staging/deployed URL to test
SYNTHETIC_USER_BASE_URL=https://staging.example.app

# Test account the persona logs in with (dedicated QA account, not your personal login)
SYNTHETIC_USER_EMAIL=qa+synthetic@example.com
SYNTHETIC_USER_PASSWORD=replace-me
